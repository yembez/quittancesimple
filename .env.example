# Supabase Configuration
VITE_SUPABASE_URL=your-supabase-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Powens Configuration (for bank aggregation)
# Get these from your Powens dashboard
POWENS_CLIENT_ID=your-powens-client-id
POWENS_CLIENT_SECRET=your-powens-client-secret
POWENS_API_URL=https://api-sandbox.powens.com  # sandbox or production
POWENS_REDIRECT_URI=https://app.quittancesimple.fr/bank-sync

# Stripe Price IDs
# Quittance Automatique
VITE_STRIPE_PRICE_AUTO_FIRST=price_xxx
VITE_STRIPE_PRICE_AUTO_ADDITIONAL=price_xxx

# Quittance Connectée+
VITE_STRIPE_PRICE_PLUS_FIRST=price_xxx
VITE_STRIPE_PRICE_PLUS_ADDITIONAL=price_xxx
