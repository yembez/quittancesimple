# Supabase Configuration
VITE_SUPABASE_URL=your-supabase-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Stripe Configuration
# Get your publishable key from: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Powens Configuration (for bank aggregation)
# Get these from your Powens dashboard
POWENS_CLIENT_ID=your-powens-client-id
POWENS_CLIENT_SECRET=your-powens-client-secret
POWENS_API_URL=https://api-sandbox.powens.com  # sandbox or production
POWENS_REDIRECT_URI=https://app.quittancesimple.fr/bank-sync

# OpenAI Configuration (for AI features)
OPENAI_API_KEY=your-openai-api-key

# Stripe Price IDs - Pack Automatique
# Mensuel
VITE_STRIPE_PRICE_AUTO_TIER1=price_1T2a6NB1aSt8zL1nyNy1v2gT   # 1-2 locataires
VITE_STRIPE_PRICE_AUTO_TIER2=price_1T2a8DB1aSt8zL1n1T0H7NPy   # 3-5 locataires
VITE_STRIPE_PRICE_AUTO_TIER3=price_1T2a8sB1aSt8zL1nbkpWQdp6   # 6+ locataires
# Annuel
VITE_STRIPE_PRICE_AUTO_TIER1_YEARLY=price_1T0sYUB1aSt8zL1nm3DDI9F3   # 1-2 locataires
VITE_STRIPE_PRICE_AUTO_TIER2_YEARLY=price_1T2e1uB1aSt8zL1nlIrT3UdR   # 3-5 locataires
VITE_STRIPE_PRICE_AUTO_TIER3_YEARLY=price_1Sqj3DB1aSt8zL1nyy6Hf5N7   # 6+ locataires
# Supabase Edge (quick-checkout) : mêmes valeurs en secrets STRIPE_PRICE_AUTO_TIER1, etc.

# Quittance Connectée+ - Ancien système
VITE_STRIPE_PRICE_PLUS_FIRST=price_xxx
VITE_STRIPE_PRICE_PLUS_ADDITIONAL=price_xxx
